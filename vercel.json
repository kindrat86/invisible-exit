{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), browsing-topics=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=3600" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=3600" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=3600" }
      ]
    },
    {
      "source": "/llms-full.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=3600" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/og/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "image/svg+xml" },
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/dashboard", "destination": "/index.html" },
    { "source": "/oto/founding", "destination": "/index.html" },
    { "source": "/confirmation", "destination": "/index.html" },
    { "source": "/checkout/success", "destination": "/index.html" },
    { "source": "/login", "destination": "/index.html" },
    { "source": "/reset-password", "destination": "/index.html" },
    { "source": "/privacy", "destination": "/index.html" },
    { "source": "/terms", "destination": "/index.html" },
    { "source": "/about", "destination": "/index.html" },
    { "source": "/admin/feature-requests", "destination": "/index.html" },
    { "source": "/fym/badge/:shareId", "destination": "/index.html" },
    { "source": "/fym", "destination": "/index.html" },
    { "source": "/idea-pipeline", "destination": "/index.html" },
    { "source": "/ideas", "destination": "/index.html" },
    { "source": "/stealth-ops", "destination": "/index.html" },
    { "source": "/launch-control", "destination": "/index.html" },
    { "source": "/brand-manager", "destination": "/index.html" },
    { "source": "/founding-member", "destination": "/index.html" },
    { "source": "/training", "destination": "/index.html" },
    { "source": "/thank-you", "destination": "/index.html" },
    { "source": "/blog", "destination": "/index.html" },
    { "source": "/blog/category/:category", "destination": "/index.html" },
    { "source": "/blog/category", "destination": "/index.html" },
    { "source": "/compare", "destination": "/index.html" },
    { "source": "/compare/:vs", "destination": "/index.html" },
    { "source": "/glossary", "destination": "/index.html" },
    { "source": "/glossary/:slug", "destination": "/index.html" },
    { "source": "/blog/:slug", "destination": "/index.html" },
    { "source": "/oto/second-tool", "destination": "/index.html" },
    { "source": "/fym/oto/founding", "destination": "/index.html" },
    { "source": "/fym/oto/second-tool", "destination": "/index.html" },
    { "source": "/fym/dashboard", "destination": "/index.html" }
  ]
}
